page {
  --green-dark: #1b4332;
  --green-main: #2d6a4f;
  --green-mid: #40916c;
  --green-light: #52b788;
  --green-pale: #d8f3dc;
  --green-bg: #edf5f0;
  --orange: #e07a2f;
  --brown: #8b5a2b;
  --text: #1b4332;
  --muted: #52796f;
  --card-shadow: 0 12rpx 40rpx rgba(27, 67, 50, 0.08);
  background: var(--green-bg);
  color: var(--text);
  font-size: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid rgba(64, 145, 108, 0.1);
}

.card-head {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-head-line {
  width: 6rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: var(--orange);
  margin-right: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--green-dark);
}

.btn-primary {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(45, 106, 79, 0.35);
}

.btn-primary[disabled] {
  background: #b7cfc3;
  color: #fff;
  box-shadow: none;
}

.msg {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 16rpx;
  min-height: 32rpx;
  text-align: center;
}

.msg.error {
  color: #e63946;
}

.msg.ok {
  color: var(--green-mid);
}
